<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Contact Us | Soapy Mutts Dog Wash — Mobile Dog Grooming in Newcastle, Gateshead and Durham</title>
  <meta name="description" content="Get in touch with Soapy Mutts Dog Wash to book a mobile dog grooming appointment in Newcastle, Gateshead or Durham. Call or send a message." />
  <link rel="stylesheet" href="/styles/redesigns/P2450.css" />
</head>
<body>

<!-- Preview Banner -->
<div style="background:#0066CC;" class="text-white text-sm text-center py-2 px-4">
  Preview redesign for <strong>Soapy Mutts Dog Wash</strong> by <a href="https://biscuitweb.co.uk" class="underline font-semibold">Biscuit Web</a> —
  <a href="https://biscuitweb.co.uk/activate?id=P2450&name=Soapy%20Mutts%20Dog%20Wash" class="underline font-bold">Get this site</a>
</div>

<!-- Nav -->
<header class="bg-white sticky top-0 z-50" style="border-bottom:1px solid #B3D1F0;">
  <div class="max-w-6xl mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/P2450/" class="flex items-center">
      <img src="/P2450/images/p379.png" alt="Soapy Mutts Dog Wash" width="120" height="99" class="h-12 w-auto" />
    </a>
    <nav class="hidden md:flex items-center gap-6">
      <a href="/P2450/" style="color:#001F3D;" class="font-medium hover:opacity-70 transition-opacity">Home</a>
      <a href="/P2450/services-html" style="color:#001F3D;" class="font-medium hover:opacity-70 transition-opacity">Services</a>
      <a href="/P2450/gallery-html" style="color:#001F3D;" class="font-medium hover:opacity-70 transition-opacity">Gallery</a>
      <a href="/P2450/contact-me-html" style="background:#0066CC;" class="text-white px-5 py-2 rounded-full font-bold hover:opacity-90 transition-opacity">Contact Us</a>
    </nav>
    <button id="menu-toggle" class="md:hidden p-2" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="hidden md:hidden" style="border-top:1px solid #B3D1F0;">
    <nav class="flex flex-col px-4 py-4 gap-4">
      <a href="/P2450/" style="color:#001F3D;" class="font-medium">Home</a>
      <a href="/P2450/services-html" style="color:#001F3D;" class="font-medium">Services</a>
      <a href="/P2450/gallery-html" style="color:#001F3D;" class="font-medium">Gallery</a>
      <a href="/P2450/contact-me-html" style="color:#0066CC;" class="font-bold">Contact Us</a>
    </nav>
  </div>
</header>

<!-- Page Hero -->
<section class="relative overflow-hidden py-20 px-4" style="min-height:38vh;">
  <div class="absolute inset-0">
    <img src="/P2450/images/1957503-orig.jpg" alt="Mobile dog grooming" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>
  <div class="relative z-10 max-w-3xl mx-auto text-center text-white flex flex-col items-center justify-center" style="min-height:38vh;">
    <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Get in Touch</h1>
    <p class="text-lg" style="opacity:0.9;">We would love to hear from you. Call us or send a message and we will get back to you as soon as we can.</p>
  </div>
</section>

<!-- Contact Section -->
<section class="py-16 px-4 bg-white">
  <div class="max-w-5xl mx-auto grid md:grid-cols-2 gap-12">

    <!-- Contact Details -->
    <div>
      <h2 class="text-2xl font-black mb-6" style="color:#001F3D;">Contact Details</h2>

      <div class="space-y-6 mb-8">
        <div class="flex gap-4 items-start p-5 rounded-2xl" style="background:#EBF3FB;border:1px solid #B3D1F0;">
          <div class="text-2xl">📞</div>
          <div>
            <p class="font-bold mb-1" style="color:#001F3D;">Phone</p>
            <a href="tel:+447946469445" class="text-lg font-semibold hover:opacity-70 transition-opacity" style="color:#0066CC;">07946 469445</a>
          </div>
        </div>

        <div class="flex gap-4 items-start p-5 rounded-2xl" style="background:#EBF3FB;border:1px solid #B3D1F0;">
          <div class="text-2xl">📍</div>
          <div>
            <p class="font-bold mb-1" style="color:#001F3D;">Location</p>
            <p style="color:#003D7A;">Coalburns, Ryton</p>
            <p class="text-sm mt-1" style="color:#003D7A;">Serving Newcastle, Gateshead and Durham</p>
          </div>
        </div>

        <div class="flex gap-4 items-start p-5 rounded-2xl" style="background:#EBF3FB;border:1px solid #B3D1F0;">
          <div class="text-2xl">📘</div>
          <div>
            <p class="font-bold mb-1" style="color:#001F3D;">Find Us Online</p>
            <div class="flex gap-4 mt-1">
              <a href="http://www.facebook.com/soapymutts" class="flex items-center gap-1 font-medium hover:opacity-70 transition-opacity" style="color:#0066CC;">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
                Facebook
              </a>
              <a href="http://twitter.com/@soapymutt" class="flex items-center gap-1 font-medium hover:opacity-70 transition-opacity" style="color:#0066CC;">
                <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
                Twitter
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Coverage Info -->
      <div class="rounded-2xl p-5" style="background:#F2F7FC;border:1px solid #B3D1F0;">
        <h3 class="font-bold mb-2" style="color:#001F3D;">Our Coverage Area</h3>
        <p class="text-sm" style="color:#003D7A;">We operate throughout Newcastle, Gateshead and Durham. Based in Ryton, we can reach most of the North East with ease. Not sure if we cover your area? Just give us a call!</p>
      </div>
    </div>

    <!-- Contact Form -->
    <div>
      <h2 class="text-2xl font-black mb-6" style="color:#001F3D;">Send a Message</h2>
      <form action="https://formspree.io/f/mwvaaojq" method="POST" class="space-y-4">
        <div>
          <label for="name" class="block font-medium mb-1 text-sm" style="color:#001F3D;">Your Name</label>
          <input
            type="text"
            id="name"
            name="name"
            required
            placeholder="e.g. Sarah Johnson"
            class="w-full px-4 py-3 rounded-xl text-sm outline-none focus:ring-2"
            style="border:1px solid #B3D1F0;background:#fff;color:#001F3D;focus-ring-color:#0066CC;"
          />
        </div>
        <div>
          <label for="phone" class="block font-medium mb-1 text-sm" style="color:#001F3D;">Phone Number</label>
          <input
            type="tel"
            id="phone"
            name="phone"
            placeholder="e.g. 07700 900123"
            class="w-full px-4 py-3 rounded-xl text-sm outline-none"
            style="border:1px solid #B3D1F0;background:#fff;color:#001F3D;"
          />
        </div>
        <div>
          <label for="email" class="block font-medium mb-1 text-sm" style="color:#001F3D;">Email Address</label>
          <input
            type="email"
            id="email"
            name="email"
            required
            placeholder="e.g. sarah@example.com"
            class="w-full px-4 py-3 rounded-xl text-sm outline-none"
            style="border:1px solid #B3D1F0;background:#fff;color:#001F3D;"
          />
        </div>
        <div>
          <label for="dog" class="block font-medium mb-1 text-sm" style="color:#001F3D;">Your Dog's Breed and Size</label>
          <input
            type="text"
            id="dog"
            name="dog"
            placeholder="e.g. Labrador, medium"
            class="w-full px-4 py-3 rounded-xl text-sm outline-none"
            style="border:1px solid #B3D1F0;background:#fff;color:#001F3D;"
          />
        </div>
        <div>
          <label for="message" class="block font-medium mb-1 text-sm" style="color:#001F3D;">Message</label>
          <textarea
            id="message"
            name="message"
            rows="4"
            placeholder="Tell us a bit about your dog and what you need..."
            class="w-full px-4 py-3 rounded-xl text-sm outline-none resize-none"
            style="border:1px solid #B3D1F0;background:#fff;color:#001F3D;"
          ></textarea>
        </div>
        <button
          type="submit"
          class="w-full py-3 rounded-xl font-bold text-white hover:opacity-90 transition-opacity"
          style="background:#0066CC;"
        >
          Send Message
        </button>
        <p class="text-xs text-center" style="color:#003D7A;">Or call us directly on <a href="tel:+447946469445" class="font-bold hover:opacity-70" style="color:#0066CC;">07946 469445</a></p>
      </form>
    </div>
  </div>
</section>

<!-- Map Section -->
<section class="py-16 px-4" style="background:#F2F7FC;">
  <div class="max-w-5xl mx-auto">
    <h2 class="text-2xl font-black text-center mb-8" style="color:#001F3D;">Find Us</h2>
    <div class="rounded-2xl overflow-hidden" style="border:2px solid #B3D1F0;height:350px;">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2305.0!2d-1.5666991!3d54.9951837!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTTCsDU5JzQyLjciTiAxwrAzMycyMC4xIlc!5e0!3m2!1sen!2suk!4v1680749596000"
        width="100%"
        height="350"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Soapy Mutts Dog Wash location map — Coalburns, Ryton"
      ></iframe>
    </div>
    <p class="text-center mt-4 text-sm" style="color:#003D7A;">Based in Coalburns, Ryton. We come to you throughout Newcastle, Gateshead and Durham.</p>
  </div>
</section>

<!-- Footer -->
<footer class="py-12 px-4" style="background:#001F3D;color:#fff;">
  <div class="max-w-6xl mx-auto grid md:grid-cols-3 gap-8 mb-8">
    <div>
      <img src="/P2450/images/p379.png" alt="Soapy Mutts Dog Wash" width="120" height="99" class="h-14 w-auto mb-4" style="filter:brightness(0) invert(1);" loading="lazy" />
      <p class="text-sm" style="color:rgba(255,255,255,0.7);">Mobile dog grooming in Newcastle, Gateshead and Durham. Serving happy hounds since 2000.</p>
    </div>
    <div>
      <h3 class="font-bold text-lg mb-4">Pages</h3>
      <ul class="space-y-2" style="color:rgba(255,255,255,0.8);">
        <li><a href="/P2450/" class="hover:text-white transition-colors">Home</a></li>
        <li><a href="/P2450/services-html" class="hover:text-white transition-colors">Services</a></li>
        <li><a href="/P2450/gallery-html" class="hover:text-white transition-colors">Gallery</a></li>
        <li><a href="/P2450/contact-me-html" class="hover:text-white transition-colors">Contact Us</a></li>
      </ul>
    </div>
    <div>
      <h3 class="font-bold text-lg mb-4">Get in Touch</h3>
      <ul class="space-y-2" style="color:rgba(255,255,255,0.8);">
        <li>Coalburns, Ryton</li>
        <li><a href="tel:+447946469445" class="hover:text-white transition-colors">07946 469445</a></li>
        <li class="flex gap-3 pt-2">
          <a href="http://www.facebook.com/soapymutts" class="hover:text-white transition-colors" aria-label="Facebook">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="http://twitter.com/@soapymutt" class="hover:text-white transition-colors" aria-label="Twitter">
            <svg width="20" height="20" fill="currentColor" viewBox="0 0 24 24"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"/></svg>
          </a>
        </li>
      </ul>
    </div>
  </div>
  <div class="max-w-6xl mx-auto pt-8 text-center text-sm" style="border-top:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.5);">
    <p>&copy; 2024 Soapy Mutts Dog Wash. All rights reserved. Coalburns, Ryton.</p>
    <p class="mt-1">This is a sample site built by <a href="https://biscuitweb.co.uk" class="underline hover:text-white">Biscuit Web</a> to showcase our work.</p>
  </div>
</footer>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

</body>
</html>
