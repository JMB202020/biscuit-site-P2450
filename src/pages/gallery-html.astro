      <a href="/P2450/contact-me-html" style="background:#0066CC;" class="text-white px-5 py-2 rounded-full font-bold hover:opacity-90 transition-opacity">Contact Us</a>
    </nav>
    <button id="menu-toggle" class="md:hidden p-2" aria-label="Open menu">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
