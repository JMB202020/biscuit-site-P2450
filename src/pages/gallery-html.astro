  </div>
  <div id="mobile-menu" class="hidden md:hidden" style="border-top:1px solid #B3D1F0;">
    <nav class="flex flex-col px-4 py-4 gap-4">
      <a href="/P2450/" style="color:#001F3D;" class="font-medium">Home</a>
      <a href="/P2450/services-html" style="color:#001F3D;" class="font-medium">Services</a>
      <a href="/P2450/gallery-html" style="color:#0066CC;" class="font-bold">Gallery</a>
      <a href="/P2450/contact-me-html" style="color:#0066CC;" class="font-bold">Contact Us</a>
    </nav>
  </div>
</header>

<!-- Page Hero -->
<section class="relative overflow-hidden py-20 px-4" style="min-height:40vh;">
  <div class="absolute inset-0">
    <img src="/P2450/images/7912964-orig.jpg" alt="Happy groomed dog" class="absolute inset-0 w-full h-full object-cover" fetchpriority="high" />
    <div class="absolute inset-0 bg-black/60"></div>
  </div>
  <div class="relative z-10 max-w-3xl mx-auto text-center text-white flex flex-col items-center justify-center" style="min-height:40vh;">
    <h1 class="text-4xl md:text-5xl font-black text-white mb-4">Our Happy Hounds</h1>
    <p class="text-lg" style="opacity:0.9;">Meet some of the gorgeous dogs we have had the pleasure of pampering over the years.</p>
  </div>
</section>

