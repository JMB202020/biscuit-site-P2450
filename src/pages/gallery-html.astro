      </div>
      <!-- Scappy -->
      <div class="group">
        <div class="aspect-square overflow-hidden rounded-2xl mb-2" style="border:2px solid #B3D1F0;">
          <img src="/P2450/images/1442035.jpg" alt="Scappy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="400" height="423" />
        </div>
        <p class="text-center font-bold text-sm" style="color:#001F3D;">Scappy</p>
      </div>
      <!-- Roxy -->
      <div class="group">
        <div class="aspect-square overflow-hidden rounded-2xl mb-2" style="border:2px solid #B3D1F0;">
          <img src="/P2450/images/1957503.jpg" alt="Roxy" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300" loading="lazy" width="400" height="300" />
        </div>
        <p class="text-center font-bold text-sm" style="color:#001F3D;">Roxy</p>
      </div>
      <!-- Unnamed -->
