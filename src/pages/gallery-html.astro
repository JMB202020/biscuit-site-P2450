  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Gallery | Soapy Mutts Dog Wash — Mobile Dog Grooming in Newcastle, Gateshead and Durham</title>
  <meta name="description" content="See our happy hounds! Photos of dogs we have groomed at Soapy Mutts Dog Wash — mobile dog grooming in Newcastle, Gateshead and Durham." />
  <link rel="stylesheet" href="/styles/redesigns/P2450.css" />
</head>
<body>

<!-- Preview Banner -->
<div style="background:#0066CC;" class="text-white text-sm text-center py-2 px-4">
  Preview redesign for <strong>Soapy Mutts Dog Wash</strong> by <a href="https://biscuitweb.co.uk" class="underline font-semibold">Biscuit Web</a> —
  <a href="https://biscuitweb.co.uk/activate?id=P2450&name=Soapy%20Mutts%20Dog%20Wash" class="underline font-bold">Get this site</a>
