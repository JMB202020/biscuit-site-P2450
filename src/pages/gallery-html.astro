    <h2 class="text-2xl md:text-3xl font-black text-center mb-2" style="color:#001F3D;">Some of Our Regulars</h2>
    <p class="text-center mb-10" style="color:#003D7A;">Say hello to Biddy, Alfie, Scappy, Roxy and the rest of the gang!</p>
    <div class="grid grid-cols-2 md:grid-cols-3 gap-4 mb-6">
      <!-- Biddy -->
      <div class="group">
        <div class="aspect-square overflow-hidden rounded-2xl mb-2" style="border:2px solid #B3D1F0;">
