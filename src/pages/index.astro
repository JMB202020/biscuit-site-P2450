  <meta name="description" content="Soapy Mutts Dog Wash — mobile dog grooming serving Newcastle, Gateshead and Durham since 2000. We come to you. Bath, clip and nail trim in our state-of-the-art grooming van." />
  <link rel="stylesheet" href="/styles/redesigns/P2450.css" />
